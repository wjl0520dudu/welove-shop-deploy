FROM node:20-alpine AS build
WORKDIR /app
COPY web/admin-web/package*.json ./
RUN npm install
COPY web/admin-web/ ./
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY deploy/frontend-runtime-config.sh /docker-entrypoint.d/40-runtime-config.sh
RUN chmod +x /docker-entrypoint.d/40-runtime-config.sh
