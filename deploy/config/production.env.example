# Non-secret production configuration. Copy to:
# /opt/welove-shop/config/production.env
# Do not put passwords, API keys, or tokens here.

# Deployment and public endpoints
GHCR_OWNER=replace-with-github-owner-lowercase
IMAGE_TAG=bootstrap
SHOP_DOMAIN=shop.example.com
ADMIN_DOMAIN=admin.shop.example.com
ALLOWED_ORIGINS=https://shop.example.com,https://admin.shop.example.com
IMAGE_BASE_URL=https://cdn.example.com

# Java services / Nacos
SPRING_PROFILES_ACTIVE=prod
NACOS_SERVER_ADDR=nacos:8848
NACOS_USERNAME=nacos
NACOS_NAMESPACE=public
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000
MAX_FILE_SIZE=50MB
UPLOAD_DIR=/data/uploads
UPLOAD_TEMP_DIR=/tmp/welove-shop

# AI service: network, retrieval and model selection (no credentials)
PG_HOST=postgres
PG_PORT=5432
PG_USER=welove_app
PG_NAME=welove_shop_search
PG_LANGGRAPH_DB=welove_shop_search
PG_BUSINESS_DB=welove_shop_search
PG_BUSINESS_SEARCH_PATH=product_svc,user_svc,trade_svc,chat_svc,admin_svc,public
JAVA_API_BASE_URL=http://gateway:8080
JAVA_API_TIMEOUT_SECONDS=5
MILVUS_URL=https://replace-with-zilliz-endpoint
MILVUS_COLLECTION=knowledge_v21_fixed
MILVUS_PRODUCT_COLLECTION=product_mm_collection
MILVUS_PRODUCT_V2_COLLECTION=product_mm_v2
MILVUS_DENSE_DIM=1024
MILVUS_IMAGE_DIM=2560
MILVUS_MULTIMODAL_DIM=2560
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_PARENT_CHILD_ENABLED=false
RAG_PARENT_CHILD_CHUNKING=recursive_v23
RAG_INITIAL_TOP_K=20
DASH_SCOPE_TEXT_EMBEDDING_MODEL=text-embedding-v4
DASH_SCOPE_TEXT_RERANK_MODEL=qwen3-rerank
DASH_SCOPE_MULTI_MODAL_EMBEDDING_MODEL=qwen3-vl-embedding
DASH_SCOPE_MULTI_MODAL_RERANK_MODEL=qwen3-vl-rerank
DASH_SCOPE_RERANK_TIMEOUT=5
SHOPPING_LLM_JUDGE_ENABLED=true
SHOPPING_LLM_JUDGE_MAX_CANDIDATES=10
SHOPPING_LLM_JUDGE_MIN_SCORE=0.55
LANGSMITH_TRACING=false

# Frontend note: both H5 frontends call same-origin /api, so no API base URL
# is required. Their image host is currently a build-time VITE_IMAGE_BASE_URL;
# keep that value aligned with IMAGE_BASE_URL until runtime frontend config is added.
