# ============================================================================
# .gitignore — welove-shop-agt (develop 分支,微服务架构)
# 说明:
#   - 单体架构相关的忽略规则请见 monolith/develop 分支的 .gitignore
#   - 本文件面向未来的 Spring Cloud 微服务 + Python ai-service
# ============================================================================

# -------- IDE / 编辑器 --------
.idea/
.vscode/
*.iml
*.ipr
*.iws
.settings/
.project
.classpath
.factorypath
.recommenders/
nbproject/private/

# -------- 操作系统噪音 --------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# -------- Java / Maven / Gradle 构建产物 --------
target/
build/
out/
bin/
.gradle/
gradle-app.setting
!gradle-wrapper.jar
.mvn/wrapper/maven-wrapper.jar
dependency-reduced-pom.xml
release.properties

# Spring Boot 打包产物
*.jar
*.war
*.ear
!**/gradle-wrapper.jar
!**/mvnw*.jar

# -------- Python (ai-service) --------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
pip-wheel-metadata/
*.pyd

# Python 虚拟环境
.venv/
venv/
env/
ENV/
.python-version

# -------- Node / 前端(uni-app + H5) --------
node_modules/
dist/
unpackage/
.next/
.nuxt/
.parcel-cache/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# -------- Android(微服务侧暂不保留 Android 项目) --------
# 完整 Android 项目源码保留在 monolith/develop 分支
backend/android/
android/
**/android/**/build/
**/android/**/.gradle/
**/android/**/local.properties
**/android/**/.cxx/

# -------- 日志与本地产物 --------
*.log
logs/
tmp/
temp/
.tmp/
*.tmp
*.bak
*.orig

# -------- 数据/存储(严禁进 Git) --------
# Docker bind mount 的中间件数据目录
volumes/
**/volumes/
# 数据库导出、备份文件
*.sqlite
*.sqlite3
*.db
*.dump
*.sql.gz
*.tar.gz
volume-backup-*/

# -------- 敏感信息(严禁进 Git) --------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.crt
*.p12
!**/gradle/wrapper/*
secrets/
credentials/

# -------- Claude / AI 工具本地配置 --------
.claude/
.agents/
.github/modernize/
.aider*
.cursorrules
.mcp.json

# -------- 微服务专属 --------
# 服务本地开发临时目录
services/**/logs/
services/**/tmp/
services/**/target/
gateway/logs/
gateway/target/
admin-bff/logs/
admin-bff/target/

# -------- 其他工具 --------
*.pid
*.seed
*.pid.lock
.DS_Store?
._*

# ============================================================================
# 单体项目遗留资源(monolith 侧的本地文件也可能会出现在这里,一并覆盖)
# 说明:.idea/target/android/volumes/__pycache__ 等已在上文覆盖,此段仅补差异项
# ============================================================================

# infra/ 下的中间件运行数据 + 单体 dev yml(不入库)
/infra/volumes/
/infra/application-dev.yml

# ai-service/ 正式入库,仅排除临时调试文件
/ai-service/tmp_debug/
/ai-service/tt
/ai-service/evals/reports/

# 单体附带的第三方二进制/文档(如果本地还留着)
/backend/

# 数据层:db/ 下的旧单体资源不入库,但 scripts/ 微服务迁移脚本入库
/db/data/
/db/*.sql
/db/*.json
/db/*.py
/db/*.md
# db/scripts/ 白名单:微服务阶段一次性迁移脚本(如 export_seed.py)入库
# -------- Token / 测试临时文件 --------
.admin_token.txt
.token_resp.json
.user_login_resp.json
.user_token.txt
web/package-lock.json

# -------- Local evaluation / planning notes (do not commit) --------
/docs/agent-evaluation-playbook.local.md
/ai-service/.pytest_cache/
/ai-service/.pytest_temp/
