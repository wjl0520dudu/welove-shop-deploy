# OpenAI-compatible LLM config.
# Do not put real secrets in this example file.
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=replace-with-your-model-name
LLM_BASE_URL=https://api.openai.com/v1

# ── RAG embedding：DashScope text-embedding-v4（主用）──
# RAG 稠密向量走这里。dashscope Python SDK 已 pip install，只需要下面两个 key。
# dimension 通过 MILVUS_DENSE_DIM 配置（1024 是我们锁的默认值，v4 也支持 2048/1536/768/512/256/128/64）。
# 改 MILVUS_DENSE_DIM 需要先跑 scripts/drop_milvus_collection.py 清库重建。
DASH_SCOPE_API_KEY=replace-with-your-dashscope-key
DASH_SCOPE_TEXT_EMBEDDING_MODEL=text-embedding-v4
DASH_SCOPE_EMBEDDING_BATCH_SIZE=10

# ── DashScope rerank (qwen3-rerank) ──
# 两阶段检索：hybrid 召回 20 条 → rerank 精排到 top 5。
# 端点用公共 dashscope.aliyuncs.com（专属部署不带 rerank 服务）。
DASH_SCOPE_RERANK_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
DASH_SCOPE_TEXT_RERANK_MODEL=qwen3-rerank
DASH_SCOPE_RERANK_TIMEOUT=5.0
# 初始召回数：hybrid 一路给 rerank 送多少候选。20 是经验值。
RAG_INITIAL_TOP_K=20

# ── Milvus + embedding 维度 ──
MILVUS_URL=http://127.0.0.1:19530
MILVUS_COLLECTION=my_rag_collection
# DashScope text-embedding-v4 支持 2048/1536/1024/768/512/256/128/64，锁 1024
MILVUS_DENSE_DIM=1024

# ── 商品多模态 collection（Phase 1b 起启用）──
# 商品向量迁到独立 collection，schema 三向量字段：text_dense + text_sparse(BM25 Function) + multimodal（预留）。
# MVP：只给 text_dense/text_sparse 建索引；tongyi-vision-flash 用于 Phase 2 图+文融合。
MILVUS_PRODUCT_COLLECTION=product_mm_collection

# tongyi-embedding-vision-flash（Phase 2 多模态图+文融合）
# 目前只在 .env 里备着，Phase 1b 商品文本仍走 DashScope text-embedding-v4，Phase 2 图片就绪后启用。
DASH_SCOPE_MULTI_MODAL_EMBEDDING_MODEL=tongyi-embedding-vision-flash-2026-03-06

# ── OpenAI 兼容通道（历史遗留，保留兼容，不再是主用 embedding）──
OPENAI_API_KEY=replace-with-your-embedding-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# RAG chunk config.
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# MySQL config for shopping recommendation.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=welove_shop_db
DB_USER=root
DB_PASSWORD=replace-with-your-db-password
DB_CHARSET=utf8mb4

# pgvector config for product vector search.
PG_HOST=localhost
PG_PORT=5432
PG_NAME=welove_shop_search
PG_USER=root
PG_PASSWORD=replace-with-your-pg-password
# PG business DB (从 MySQL 迁移过来的业务主库)
PG_BUSINESS_DB=welove_shop_db

# Java 后端服务地址（Python agent 通过 HTTP 调 Java 拿业务数据：收藏/浏览/订单等）
# 超时默认 2s（Java 挂时快速失败走 PG 降级），生产可根据 Java 实际响应时长拉到 5-10s
JAVA_API_BASE_URL=http://localhost:8888
JAVA_API_TIMEOUT_SECONDS=2

# LangSmith 追踪配置（可观测性）。留空则不上报，不影响功能。
# 生产环境建议开启，能看到每次 LLM 调用的完整链路 + token 消耗。
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=welove-shop-ai

# CORS 允许的前端来源（逗号分隔）。生产环境务必明确列出前端域名，不要用 "*"。
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080

# ── 博查 Web 搜索兜底（KnowledgeAgent 内部知识库不足时自动触发）──
# 不配置 BOCHA_API_KEY 时不启用兜底，KnowledgeAgent 行为不变。
# 申请地址：https://open.bochaai.com/
BOCHA_API_KEY=
# MCP 启动命令（默认 uvx，也可换成 npx 或留空走 HTTP 直连）
BOCHA_MCP_COMMAND=uvx
# 博查兜底超时秒数（兜底不应拖慢主流程）
BOCHA_SEARCH_TIMEOUT=5.0

# Optional integration test config.
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
RUN_EMBEDDING_TESTS=0
RUN_MILVUS_TESTS=0
RUN_DASHSCOPE_TESTS=0
